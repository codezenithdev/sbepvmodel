# Copy this file to .env (or set these as real environment variables) and fill in your key.
# The script reads BAZEFIELD_API_KEY / BAZEFIELD_BASE_URL from the environment.
# Do NOT commit your real key.

# Required: your Bazefield API key (from the Bazefield User Manager).
BAZEFIELD_API_KEY=your-key-here

# Optional: defaults to https://bazefield.sbenergy-us.com/Bazefield.Services/api/
# BAZEFIELD_BASE_URL=https://bazefield.sbenergy-us.com/Bazefield.Services/api/

# Required for the dashboard chat endpoint.
OPENAI_API_KEY=your-openai-key-here

# Required for a shared Render deployment. Leave unset for unprotected local dev.
DASHBOARD_BASIC_USER=cliff
DASHBOARD_BASIC_PASSWORD=replace-with-a-strong-shared-password

# Optional: defaults in app.py if omitted.
# OPENAI_MODEL=gpt-5.5

# Optional: defaults to ./outputs locally. On Render, use a persistent disk and set:
# PV_DASHBOARD_OUTPUT_DIR=/var/data/outputs

# Optional: comma-separated origins allowed to call the FastAPI model API from
# a hosted Sites dashboard. Add the deployed Sites URL when live API mode is used.
# PV_DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
